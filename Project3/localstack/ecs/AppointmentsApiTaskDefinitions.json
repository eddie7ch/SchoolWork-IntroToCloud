{
  "family": "Appointments",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "appointments-api",
      "image": "appointments-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000
        }
      ]
    }
  ]
}
